# Database
DATABASE_URL=postgresql+asyncpg://stylist:stylist@localhost:5432/stylist
DATABASE_URL_SYNC=postgresql://stylist:stylist@localhost:5432/stylist

# Redis
REDIS_URL=redis://localhost:6379/0

# API Keys — required for full functionality
GOOGLE_VISION_API_KEY=your_google_vision_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# App settings
APP_ENV=development
SECRET_KEY=change-me-to-something-random-in-production
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Scraping behaviour
SCRAPE_DELAY_MIN=1.5
SCRAPE_DELAY_MAX=4.0
MAX_PRODUCTS_PER_RUN=200

# Matching thresholds
COLOR_MATCH_THRESHOLD=70
