# Copy to backend/.env and fill in your values

# Required API keys
GOOGLE_VISION_API_KEY=your_google_vision_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database (auto-set by docker-compose for local dev)
DATABASE_URL=postgresql+asyncpg://stylist:stylist@localhost:5432/stylist
DATABASE_URL_SYNC=postgresql://stylist:stylist@localhost:5432/stylist

# Redis
REDIS_URL=redis://localhost:6379/0
